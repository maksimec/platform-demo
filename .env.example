# ── General ──────────────────────────────────────────────────────────
LETSENCRYPT_EMAIL=admin@example.com
BOOKSTORE_DOMAIN=example.com

# ── PostgreSQL ───────────────────────────────────────────────────────
POSTGRES_DB=bookstore
POSTGRES_USER=bookstore
POSTGRES_PASSWORD=change_this_db_password

# ── JWT / Session ────────────────────────────────────────────────────
JWT_SECRET=change_this_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
SESSION_SECRET=change_this_session_secret_min_32_chars

# ── Service ports (internal) ─────────────────────────────────────────
FRONTEND_PORT=3000
CATALOG_PORT=5001
ORDER_PORT=5002
AUTH_PORT=5003

# ── Docker Registry ──────────────────────────────────────────────────
REGISTRY_HOST=registry.example.com
REGISTRY_USERNAME=registryuser
REGISTRY_PASSWORD=change_this_registry_password
